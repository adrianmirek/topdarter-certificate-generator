{
  "name": "certificate-render-vercel",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic certificate image rendering service for Vercel using sharp.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "express": "^4.21.2",
    "sharp": "^0.34.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@vercel/node": "^5.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
